# ============================================
# ENVIRONMENT VARIABLES CHECKLIST
# ============================================
# Fill in the values you have. Leave blank if you don't have it yet.

# ── 1. DATABASE (Supabase) ──────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=

# ── 2. AUTH (Required for Render) ───────────
# Generate a strong random string (32+ chars)
JWT_SECRET=

# ── 3. APP URL ──────────────────────────────
# Your Render backend URL or custom domain
NEXT_PUBLIC_BASE_URL=

# ── 4. CLOUDINARY (File/Image Storage) ──────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── 5. FIREBASE (Frontend Hosting) ──────────
# Get from: Firebase Console → Project Settings → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── 6. SUPABASE (Client-side, Optional) ─────
# Only needed if you want Realtime subscriptions
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=