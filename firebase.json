{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "destination": "https://employee-panel-clicktake.onrender.com/api/**"
      },
      {
        "source": "**",
        "destination": "https://employee-panel-clicktake.onrender.com"
      }
    ],
    "headers": [
      {
        "source": "/api/**",
        "headers": [
          { "key": "X-Forwarded-Host", "value": "panel-clicktake.web.app" },
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      }
    ]
  }
}